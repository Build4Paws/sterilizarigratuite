# API Lambda — environment variables (reference only; this file is committed,
# real values are NOT). Set these on the function (Console → Configuration →
# Environment variables) or, preferably, back the secrets with AWS Secrets
# Manager / SSM Parameter Store and reference them. deploy.sh never writes these.
#
# SECURITY: never commit real secrets. DB passwords, TOKEN_PEPPER and the
# Turnstile secret must come from a secrets store, not literals.

# --- Cloudflare Turnstile (captcha) ---
# Server-side secret for siteverify. Pairs with the PUBLIC site key the
# frontend renders (NUXT_PUBLIC_TURNSTILE_SITE_KEY in frontend/.env).
TURNSTILE_SECRET=<YOUR_TURNSTILE_SECRET_KEY>
# Optional kill-switch; defaults to "true". Set "false" ONLY in non-prod to
# bypass verification. Legacy HCAPTCHA_SECRET / HCAPTCHA_ENABLED are still read
# as a fallback so a code deploy doesn't break before you rename the vars.
TURNSTILE_ENABLED=true

# --- Token pepper (HMAC for magic-link tokens) ---
TOKEN_PEPPER=<YOUR_TOKEN_PEPPER>

# --- Per-environment Postgres (PREFIX = PROD or DEV) ---
PROD_PG_HOST=
PROD_PG_PORT=5432
PROD_PG_DB=
PROD_PG_USER=
PROD_PG_PASSWORD=<YOUR_DB_PASSWORD>
DEV_PG_HOST=
DEV_PG_PORT=5432
DEV_PG_DB=
DEV_PG_USER=
DEV_PG_PASSWORD=<YOUR_DB_PASSWORD>

# --- Per-environment CORS allow-origin (also used as site_url in emails) ---
PROD_ALLOWED_ORIGIN=https://sterilizarigratuite.ro
DEV_ALLOWED_ORIGIN=https://dev.sterilizarigratuite.ro

# --- Email (SES) ---
SES_SENDER=
SES_REGION=eu-central-1

# --- SMS (messengeros) ---
# Server-side x-api-key for the Send API. Empty = SMS skipped (no-op).
# NOTE: messengeros is a third-party host, so the Lambda needs real internet
# egress (NAT) to reach it — an SES VPC endpoint does NOT cover it.
MESSENGEROS_API_KEY=<YOUR_MESSENGEROS_API_KEY>
# The SMS channel/provider id from your messengeros account (required to send).
MESSENGEROS_DELIVERY_PROVIDER=
# Optional: defaults server-side if omitted.
MESSENGEROS_PROJECT=
# Optional override; defaults to the documented endpoint.
MESSENGEROS_SMS_URL=https://inbound.messengeros.com/2.0/send

# --- Misc ---
RATE_LIMIT_PER_IP_PER_HOUR=20
