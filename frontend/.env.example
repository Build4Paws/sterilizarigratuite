NUXT_PUBLIC_SITE_URL=https://sterilizarigratuite.ro
# hCaptcha public site key — renders the widget in the browser
NUXT_PUBLIC_HCAPTCHA_SITE_KEY=

# Server-only (DO NOT prefix with NUXT_PUBLIC_ — these must stay on the server)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=eu-central-1
AWS_API_BASE=https://api.sterilizarigratuite.ro

# HCAPTCHA_SECRET_KEY is no longer used by the Nuxt server routes.
# hCaptcha verification is handled exclusively by the AWS backend.
# The frontend forwards the token as-is in the POST body.
