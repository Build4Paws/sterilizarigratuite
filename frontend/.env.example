NUXT_PUBLIC_SITE_URL=
# Cloudflare Turnstile public site key — renders the widget in the browser.
# Required: the backend rejects any submission without a token (schema requires
# turnstileToken). Must be the site key paired with the Lambda's TURNSTILE_SECRET
# (Cloudflare dashboard → Turnstile → your widget → Site Key). Leave empty in
# local dev to skip the captcha entirely.
NUXT_PUBLIC_TURNSTILE_SITE_KEY=

# Server-only (DO NOT prefix with NUXT_PUBLIC_ — these must stay on the server)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=eu-central-1
AWS_API_BASE=

# Cloudflare Turnstile SECRET — server-only (DO NOT prefix with NUXT_PUBLIC_).
# Verification runs in the Nuxt register/submit proxies on EC2 (the VPC Lambda
# has no internet egress to reach Cloudflare). Pairs with the public site key
# above. Empty = dev mode (captcha skipped). When set here, set the Lambda's
# TURNSTILE_ENABLED=false so it doesn't re-verify the single-use token.
NUXT_TURNSTILE_SECRET_KEY=<YOUR_TURNSTILE_SECRET_KEY>

# messengeros (SMS) service-account login — server-only. Powers the admin "SMS"
# section (server/utils/messengeros.ts), which logs in to /backend/auth/login to
# get a Bearer JWT for the /backend/* API. Use a dedicated service account.
# (The /2.0/send x-api-key is separate and lives in the Lambda, not here.)
NUXT_MESSENGEROS_EMAIL=<YOUR_MESSENGEROS_EMAIL>
NUXT_MESSENGEROS_PASSWORD=<YOUR_MESSENGEROS_PASSWORD>

# --- Admin auth (Amazon Cognito User Pool) — server-only ---
# Powers /admin login. See docs/ADMIN-PLAN.md for the pool setup.
# Defaults to AWS_REGION if unset.
COGNITO_REGION=eu-central-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
# App-client secret — stays server-side, used to compute the SECRET_HASH.
# NEVER expose to the browser / NUXT_PUBLIC_*.
COGNITO_CLIENT_SECRET=
